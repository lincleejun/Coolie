{
  "name": "coolie",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "engines": { "node": ">=22" },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc -b packages/protocol packages/server packages/cli && tsc --noEmit -p packages/client",
    "sidecar:spike": "node packages/server/scripts/build-sidecar-spike.mjs && node packages/server/scripts/smoke-sidecar-spike.mjs",
    "sidecar:spike:self-check": "node packages/server/scripts/build-sidecar-spike.mjs --self-check",
    "postinstall": "find node_modules -path '*node-pty*' -name spawn-helper -exec chmod +x {} + 2>/dev/null || true"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^3.0.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0",
    "postject": "1.0.0-alpha.6"
  },
  "trustedDependencies": ["node-pty", "better-sqlite3"]
}
