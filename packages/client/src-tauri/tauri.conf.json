{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Coolie",
  "version": "0.1.0",
  "identifier": "app.coolie.client",
  "build": {
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev:vite",
    "frontendDist": "../dist",
    "beforeBuildCommand": "bun run build:vite"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Coolie",
        "width": 1440,
        "height": 900,
        "minWidth": 980,
        "minHeight": 600,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": { "csp": null }
  },
  "plugins": {
    "deep-link": {
      "desktop": { "schemes": ["coolie"] }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "macOS": { "minimumSystemVersion": "12.0" }
  }
}
