{
  "name": "@coolie/client",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:vite": "vite",
    "dev:web": "vite --config vite.web.config.ts",
    "build:vite": "vite build",
    "build:vite:packaged": "COOLIE_VITE_PACKAGED=1 vite build",
    "build:sidecar": "bun run --cwd ../.. sidecar:build",
    "build:release-assets": "bun run build:vite:packaged && bun run build:sidecar",
    "build:web": "vite build --config vite.web.config.ts",
    "build:app": "tauri build",
    "build:app:release": "tauri build --config src-tauri/tauri.conf.json",
    "build:app:test": "COOLIE_VITE_PACKAGED=1 VITE_COOLIE_WDIO=1 VITE_COOLIE_MOCK_SERVER=45123:mock-e2e tauri build --debug --config src-tauri/tauri.packaged-test.conf.json",
    "test:tauri": "VITE_COOLIE_WDIO=1 VITE_COOLIE_MOCK_SERVER=45123:mock-e2e wdio run wdio.conf.ts",
    "test:tauri:mock": "COOLIE_TAURI_SUITE=mock VITE_COOLIE_WDIO=1 VITE_COOLIE_MOCK_SERVER=45123:mock-e2e wdio run wdio.conf.ts --suite mock",
    "test:tauri:real": "COOLIE_TAURI_SUITE=real VITE_COOLIE_WDIO=1 wdio run wdio.conf.ts --suite real",
    "test:tauri:native": "COOLIE_TAURI_SUITE=native VITE_COOLIE_WDIO=1 VITE_COOLIE_MOCK_SERVER=45123:mock-e2e wdio run wdio.conf.ts --suite native",
    "test:tauri:release": "VITE_COOLIE_WDIO=1 wdio run wdio.release.conf.ts",
    "test:tauri:release:native": "COOLIE_PACKAGED_SUITE=native VITE_COOLIE_WDIO=1 wdio run wdio.release.conf.ts",
    "test:tauri:release:mock": "COOLIE_PACKAGED_SUITE=mock VITE_COOLIE_WDIO=1 wdio run wdio.release.conf.ts",
    "tauri": "tauri"
  },
  "dependencies": {
    "@coolie/protocol": "workspace:*",
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-deep-link": "2",
    "@tauri-apps/plugin-dialog": "2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "0.20.0-beta.287",
    "@xterm/xterm": "^6.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@wdio/cli": "^9.20.0",
    "@wdio/junit-reporter": "^9.20.0",
    "@wdio/local-runner": "^9.20.0",
    "@wdio/mocha-framework": "^9.20.0",
    "@wdio/spec-reporter": "^9.20.0",
    "@wdio/tauri-plugin": "^1.0.0",
    "@wdio/tauri-service": "^1.0.0",
    "@types/ws": "^8.5.13",
    "ws": "^8.18.0",
    "@tauri-apps/cli": "^2.9.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "@wdio/native-utils": "2.5.0"
  }
}
